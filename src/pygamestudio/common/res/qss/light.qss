/* ================================================
   VS Code Light Theme for PySide6
   ================================================ */

/* ----- 全局基础样式 ----- */
QWidget {
    background-color: #f3f3f3;
    color: #333333;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    font-size: 13px;
    border: none;
    outline: 0px;
}

/* ----- 主窗口 ----- */
QMainWindow {
    background-color: #f3f3f3;
}

QMainWindow::separator {
    background-color: #d0d0d0;
    width: 1px;
    height: 1px;
}

/* ----- 菜单栏 ----- */
QMenuBar {
    background-color: #dddddd;
    color: #333333;
    padding: 4px 0px;
    border-bottom: 1px solid #c8c8c8;
}

QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #c8c8c8;
}

QMenuBar::item:pressed {
    background-color: #b8b8b8;
}

/* ----- 菜单 ----- */
QMenu {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #c8c8c8;
    padding: 4px 0px;
    margin: 2px 0px 0px 0px;
}

QMenu::item {
    padding: 6px 30px 6px 30px;
    border: 1px solid transparent;
}

QMenu::item:selected {
    background-color: #0060c0;
    color: #ffffff;
}

QMenu::separator {
    height: 1px;
    background-color: #e0e0e0;
    margin: 4px 8px;
}

QMenu::indicator {
    width: 13px;
    height: 13px;
}

/* ----- 工具栏 ----- */
QToolBar {
    background-color: #dddddd;
    border: none;
    border-bottom: 1px solid #c8c8c8;
    spacing: 3px;
    padding: 3px;
}

QToolBar::separator {
    background-color: #c8c8c8;
    width: 1px;
    margin: 4px 4px;
}

QToolButton {
    background-color: transparent;
    color: #333333;
    border-radius: 4px;
    padding: 4px 8px;
}

QToolButton:hover {
    background-color: #c8c8c8;
}

QToolButton:pressed {
    background-color: #b8b8b8;
}

QToolButton:checked {
    background-color: #0060c0;
    color: #ffffff;
}

/* ----- 状态栏 ----- */
QStatusBar {
    background-color: #007acc;
    color: #ffffff;
    border-top: 1px solid #c8c8c8;
}

QStatusBar::item {
    border: none;
}

/* ----- 按钮 ----- */
QPushButton {
    background-color: #007acc;
    color: #ffffff;
    border: 1px solid #007acc;
    border-radius: 2px;
    padding: 6px 14px;
    font-weight: normal;
}

QPushButton:hover {
    background-color: #1e8ad4;
    border-color: #1e8ad4;
}

QPushButton:pressed {
    background-color: #005a9e;
    border-color: #005a9e;
}

QPushButton:disabled {
    background-color: #e0e0e0;
    border-color: #d0d0d0;
    color: #999999;
}

QPushButton:default {
    border: 2px solid #005a9e;
}

/* 次要按钮 */
QPushButton[secondary="true"] {
    background-color: #e0e0e0;
    border-color: #d0d0d0;
    color: #333333;
}

QPushButton[secondary="true"]:hover {
    background-color: #d0d0d0;
    border-color: #c0c0c0;
}

/* ----- 输入框 ----- */
QLineEdit, QTextEdit, QPlainTextEdit, QSpinBox, QDoubleSpinBox {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 2px;
    padding: 4px 6px;
    selection-background-color: #0060c0;
    selection-color: #ffffff;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus, 
QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #007acc;
    background-color: #ffffff;
}

QLineEdit:disabled, QTextEdit:disabled, QPlainTextEdit:disabled {
    background-color: #f5f5f5;
    color: #999999;
    border-color: #e0e0e0;
}

/* ----- 滚动条 ----- */
QScrollBar:vertical {
    background-color: #f3f3f3;
    width: 14px;
    margin: 0px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #c8c8c8;
    min-height: 30px;
    border-radius: 7px;
    margin: 2px 2px;
}

QScrollBar::handle:vertical:hover {
    background-color: #b0b0b0;
}

QScrollBar::handle:vertical:pressed {
    background-color: #909090;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background-color: #f3f3f3;
}

QScrollBar:horizontal {
    background-color: #f3f3f3;
    height: 14px;
    margin: 0px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: #c8c8c8;
    min-width: 30px;
    border-radius: 7px;
    margin: 2px 2px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #b0b0b0;
}

QScrollBar::handle:horizontal:pressed {
    background-color: #909090;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
    border: none;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background-color: #f3f3f3;
}

/* ----- 标签页 ----- */
QTabWidget {
    background-color: #f3f3f3;
}

QTabWidget::pane {
    background-color: #f3f3f3;
    border: 1px solid #d0d0d0;
    border-top: none;
    top: -1px;
}

QTabBar::tab {
    background-color: #e0e0e0;
    color: #333333;
    padding: 8px 16px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    min-width: 80px;
}

QTabBar::tab:selected {
    background-color: #f3f3f3;
    color: #000000;
    border-bottom: 2px solid #007acc;
}

QTabBar::tab:hover:!selected {
    background-color: #d0d0d0;
}

QTabBar::tab:first {
    margin-left: 0px;
}

QTabBar::tab:only-one {
    margin: 0px;
}

QTabBar::close-button {
    image: url(none);
    border-radius: 2px;
    background-color: transparent;
}

QTabBar::close-button:hover {
    background-color: #e81123;
}

/* ----- 分组框 ----- */
QGroupBox {
    background-color: transparent;
    color: #333333;
    font-weight: bold;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    margin-top: 12px;
    padding-top: 8px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0px 6px 0px 6px;
    background-color: #f3f3f3;
}

/* ----- 复选框 / 单选框 ----- */
QCheckBox, QRadioButton {
    background-color: transparent;
    color: #333333;
    spacing: 8px;
    padding: 4px 0px;
}

QCheckBox::indicator, QRadioButton::indicator {
    width: 16px;
    height: 16px;
}

QCheckBox::indicator:unchecked, QRadioButton::indicator:unchecked {
    background-color: #ffffff;
    border: 1px solid #b0b0b0;
    border-radius: 2px;
}

QRadioButton::indicator:unchecked {
    border-radius: 8px;
}

QCheckBox::indicator:unchecked:hover, QRadioButton::indicator:unchecked:hover {
    border-color: #007acc;
}

QCheckBox::indicator:checked {
    background-color: #007acc;
    border: 1px solid #007acc;
    border-radius: 2px;
}

QRadioButton::indicator:checked {
    background-color: #007acc;
    border: 1px solid #007acc;
    border-radius: 8px;
}

QCheckBox::indicator:checked:hover, QRadioButton::indicator:checked:hover {
    background-color: #1e8ad4;
}

/* ----- 下拉框 ----- */
QComboBox {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 2px;
    padding: 4px 8px;
    min-width: 80px;
}

QComboBox:hover {
    border-color: #a0a0a0;
}

QComboBox:focus {
    border-color: #007acc;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #d0d0d0;
}

QComboBox::down-arrow {
    width: 10px;
    height: 10px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #c8c8c8;
    selection-background-color: #0060c0;
    selection-color: #ffffff;
    outline: 0px;
}

QComboBox QAbstractItemView::item {
    padding: 6px 12px;
    min-height: 24px;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #0060c0;
}

/* ----- 列表控件 ----- */
QListView, QListWidget {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 2px;
    outline: 0px;
    padding: 2px;
}

QListView::item, QListWidget::item {
    padding: 6px 8px;
    border: none;
}

QListView::item:selected, QListWidget::item:selected {
    background-color: #0060c0;
    color: #ffffff;
}

QListView::item:hover:!selected, QListWidget::item:hover:!selected {
    background-color: #e8e8e8;
}

/* ----- 树形控件 ----- */
QTreeView, QTreeWidget {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 2px;
    outline: 0px;
    alternate-background-color: #f8f8f8;
}

QTreeView::item, QTreeWidget::item {
    padding: 4px 4px;
    border: none;
}

QTreeView::item:selected, QTreeWidget::item:selected {
    background-color: #0060c0;
    color: #ffffff;
}

QTreeView::item:hover:!selected, QTreeWidget::item:hover:!selected {
    background-color: #e8e8e8;
}

QTreeView::branch:has-children:!has-siblings,
QTreeView::branch:closed:has-children:has-siblings {
    border-image: none;
}

QTreeView::branch:open:has-children:!has-siblings,
QTreeView::branch:open:has-children:has-siblings {
    border-image: none;
}

/* ----- 表格 ----- */
QTableView, QTableWidget {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #d0d0d0;
    border-radius: 2px;
    gridline-color: #e0e0e0;
    outline: 0px;
    alternate-background-color: #f8f8f8;
}

QTableView::item, QTableWidget::item {
    padding: 4px 8px;
    border: none;
    border-bottom: 1px solid #e0e0e0;
}

QTableView::item:selected, QTableWidget::item:selected {
    background-color: #0060c0;
    color: #ffffff;
}

QTableView::item:hover:!selected, QTableWidget::item:hover:!selected {
    background-color: #e8e8e8;
}

QHeaderView::section {
    background-color: #e8e8e8;
    color: #333333;
    padding: 6px 8px;
    border: none;
    border-right: 1px solid #d0d0d0;
    border-bottom: 1px solid #d0d0d0;
    font-weight: bold;
}

QHeaderView::section:hover {
    background-color: #d8d8d8;
}

QHeaderView::section:checked {
    background-color: #0060c0;
    color: #ffffff;
}

/* ----- 进度条 ----- */
QProgressBar {
    background-color: #e0e0e0;
    color: #333333;
    border: none;
    border-radius: 2px;
    text-align: center;
    height: 20px;
}

QProgressBar::chunk {
    background-color: #007acc;
    border-radius: 2px;
}

/* ----- 滑块 ----- */
QSlider::groove:horizontal {
    background-color: #d0d0d0;
    height: 4px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #007acc;
    width: 14px;
    height: 14px;
    margin: -5px 0px;
    border-radius: 7px;
    border: 1px solid #ffffff;
}

QSlider::handle:horizontal:hover {
    background-color: #1e8ad4;
}

QSlider::sub-page:horizontal {
    background-color: #007acc;
    border-radius: 2px;
}

QSlider::groove:vertical {
    background-color: #d0d0d0;
    width: 4px;
    border-radius: 2px;
}

QSlider::handle:vertical {
    background-color: #007acc;
    width: 14px;
    height: 14px;
    margin: 0px -5px;
    border-radius: 7px;
    border: 1px solid #ffffff;
}

QSlider::handle:vertical:hover {
    background-color: #1e8ad4;
}

QSlider::sub-page:vertical {
    background-color: #007acc;
    border-radius: 2px;
}

/* ----- 分割线 ----- */
QSplitter::handle {
    background-color: #d0d0d0;
}

QSplitter::handle:horizontal {
    width: 3px;
}

QSplitter::handle:vertical {
    height: 3px;
}

QSplitter::handle:hover {
    background-color: #007acc;
}

/* ----- 停靠窗口 ----- */
QDockWidget {
    titlebar-close-icon: url(none);
    titlebar-normal-icon: url(none);
}

QDockWidget::title {
    background-color: #dddddd;
    padding: 8px 12px;
    border-bottom: 1px solid #c8c8c8;
    text-align: left;
}

QDockWidget::close-button, QDockWidget::float-button {
    background-color: transparent;
    border: none;
    padding: 0px;
    margin: 0px;
}

/* ----- 工具提示 ----- */
QToolTip {
    background-color: #ffffff;
    color: #333333;
    border: 1px solid #c8c8c8;
    padding: 4px 8px;
    border-radius: 2px;
}

/* ----- 输入对话框 ----- */
QInputDialog {
    background-color: #f3f3f3;
}

/* ----- 日历控件 ----- */
QCalendarWidget {
    background-color: #ffffff;
}

QCalendarWidget QToolButton {
    background-color: transparent;
    color: #333333;
}

QCalendarWidget QMenu {
    background-color: #ffffff;
}

QCalendarWidget QSpinBox {
    background-color: #ffffff;
}

/* ----- 禁用状态通用样式 ----- */
*:disabled {
    color: #999999;
}